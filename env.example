# ── Study Buddy Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values

# Flask secret key (change this to a random string)
SECRET_KEY=change-this-to-a-random-secret-string

# Groq API key
GROQ_API_KEY=your_groq_api_key_here

# MongoDB connection string
# Local:  mongodb://localhost:27017/
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017/

# Gmail SMTP (for OTP emails)
# Use a Gmail App Password, NOT your real Gmail password
# Steps: Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password_here
